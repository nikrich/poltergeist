# Environment variables for ghostbrain connectors and secrets.
#
# Setup
# -----
#   Dev:               copy to .env in this directory (already gitignored).
#   Installed app:     copy to ~/.ghostbrain/.env — the packaged sidecar
#                      reads from there first, falling back to <cwd>-upward.
#
# Values left set to placeholders are inactive. The connector treats a
# missing env var the same as an empty string.

# ---------------------------------------------------------------------------
# Slack — User OAuth tokens (one per workspace slug from routing.yaml).
# Naming: SLACK_TOKEN_<UPPER_SLUG>, with non-word chars replaced by `_`.
# A slug like "my-team" → SLACK_TOKEN_MY_TEAM. xoxp- (User) or xoxb- (Bot).
# ---------------------------------------------------------------------------
SLACK_TOKEN_ACME=xoxp-replace-with-real-token

# ---------------------------------------------------------------------------
# Slack — Allowed-channels whitelist (full-pull mode only).
#
# Slack rate-limits conversations.history at ~50 req/min per workspace.
# In a workspace with hundreds of channels, full-pull will exhaust that
# budget every tick and silently return zero events. The allowlist
# restricts which channels get pulled.
#
# Naming: SLACK_ALLOWED_CHANNELS_<UPPER_SLUG>. Comma-separated names,
# with or without leading `#`, case-insensitive.
#
# Set this rather than `allowed_channels:` in routing.yaml when channel
# names could leak project / team info — the .env file isn't tracked.
# ---------------------------------------------------------------------------
SLACK_ALLOWED_CHANNELS_ACME=general,engineering,project-alpha

# ---------------------------------------------------------------------------
# Atlassian — Jira + Confluence share one API token per Atlassian account.
# ---------------------------------------------------------------------------
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_TOKEN_ACME=replace-with-real-api-token
