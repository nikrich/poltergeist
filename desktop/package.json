{
  "name": "ghostbrain-desktop",
  "version": "0.8.0",
  "description": "Poltergeist \u2014 local-first second brain desktop app",
  "homepage": "https://github.com/nikrich/poltergeist",
  "author": {
    "name": "Jannik Richter",
    "email": "jannik@codeship.tech"
  },
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --mac --arm64",
    "pack:unsigned": "SKIP_NOTARIZE=1 CSC_IDENTITY_AUTO_DISCOVERY=false electron-vite build && electron-builder --mac --arm64 -c.mac.identity=null",
    "pack:linux": "electron-vite build && electron-builder --linux --x64",
    "pack:win": "electron-vite build && electron-builder --win --x64",
    "typecheck": "tsc -b tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:record": "node scripts/demo/record.mjs",
    "demo:post": "scripts/demo/postprocess.sh",
    "demo": "electron-vite build && node scripts/demo/record.mjs && scripts/demo/postprocess.sh"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@tanstack/react-query": "^5.100.9",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@tiptap/suggestion": "^2.27.2",
    "@uiw/react-codemirror": "^4.25.10",
    "lucide-react": "^1.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tiptap-markdown": "^0.8.10",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.61.1",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
